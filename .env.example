# ── Banco de dados (obrigatório) ─────────────────────────────────────────────
# DATABASE_URL: conexão usada em runtime (pode ser pooler).
# DIRECT_URL: conexão direta para migrations e seed (Prisma 7).
DATABASE_URL="postgresql://usuario:senha@localhost:5432/clinica"
DIRECT_URL="postgresql://usuario:senha@localhost:5432/clinica"

# ── NextAuth (obrigatório) ───────────────────────────────────────────────────
NEXTAUTH_SECRET="gere-um-segredo-aleatorio-longo"
NEXTAUTH_URL="http://localhost:3000"

# ── Aplicação (opcional) ─────────────────────────────────────────────────────
# Fuso horário da clínica (padrão: America/Sao_Paulo)
CLINIC_TZ="America/Sao_Paulo"

# URL pública usada em links absolutos (fallback: NEXTAUTH_URL / VERCEL_URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Chat em tempo real (opcional) ────────────────────────────────────────────
# Vercel não executa server.ts; o padrão em VERCEL=1 é polling HTTP (sem WebSocket).
# Para realtime completo, hospede server.ts (Railway/Render) e aponte o cliente:
# NEXT_PUBLIC_REALTIME_ENABLED="true"
# NEXT_PUBLIC_SOCKET_URL="https://seu-servidor-socket.example.com"

# ── Upload de arquivos do chat (obrigatório na Vercel) ───────────────────────
# Storage → Blob → conecte ao projeto. Na Vercel usa OIDC (BLOB_STORE_ID) ou token.
# Para dev local: vercel env pull
# BLOB_READ_WRITE_TOKEN=""

# ── Demo de portfólio (opcional) ─────────────────────────────────────────────
# Ativa login automático sem banco para demonstração pública.
# PORTFOLIO_DEMO_AUTH="true"
# Conta principal de demonstração (único SUPER_ADMIN após seed/consolidação).
# DEMO_LOGIN_EMAIL="demo@clinica.local"
# DEMO_LOGIN_PASSWORD="demo123456"

# ── Cron (opcional) ──────────────────────────────────────────────────────────
# Protege rotas de cron. Se vazio, ficam abertas (apenas dev local).
# CRON_SECRET="segredo-do-cron"
# NEXT_PUBLIC_APP_URL="https://seu-app.vercel.app"  (também no GitHub Actions: vars ou secrets)
# /api/cron/cancel-unconfirmed — cancela consultas não atendidas do dia anterior (1x/dia via vercel.json)
# /api/notification/process-reminders — lembretes (GitHub Actions a cada 5 min em produção; automático em dev via server.ts)
# Alternativas ao GitHub Actions: cron-job.org, EasyCron. No Vercel Pro, aponte o cron nativo para a mesma rota.

# ── APIs externas da agenda (opcional) ───────────────────────────────────────
# Bearer token + rate limit via createApiGuard. Se vazio, a rota fica aberta.
# SCHEDULE_API_SECRET=""
# SCHEDULE_AVAILABILITY_SECRET=""
# SCHEDULE_OPTIONS_SECRET=""
