generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id              Int             @id @default(autoincrement())
  name            String          @map("nome")
  birthDate       String?         @map("dataNascimento")
  gender          String?         @map("sexo")
  cpf             String?         @unique
  phone           String?         @map("telefone")
  email           String?
  zipCode         String?         @map("cep")
  street          String?         @map("logradouro")
  number          String?         @map("numero")
  complement      String?         @map("complemento")
  neighborhood    String?         @map("bairro")
  city            String?         @map("cidade")
  state           String?         @map("uf")
  insurancePlan   String?         @map("convenio")
  insuranceNumber String?         @map("numeroConvenio")
  notes           String?         @map("observacoes")
  maritalStatus   String?         @map("estadoCivil")
  education       String?         @map("escolaridade")
  religion        String?         @map("religiao")
  profession      String?         @map("profissao")
  createdAt       DateTime        @default(now())
  appointments    Appointment[]
  clinicalCharts  ClinicalChart[]

  @@map("pacientes")
}

model Doctor {
  id             Int           @id @default(autoincrement())
  name           String        @map("nome")
  crm            String?
  specialty      String?       @map("especialidade")
  gender         String?       @map("sexo")
  cpf            String?
  birthDate      String?       @map("dataNascimento")
  phone          String?       @map("telefone")
  email          String?
  zipCode        String?       @map("cep")
  street         String?       @map("logradouro")
  number         String?       @map("numero")
  complement     String?       @map("complemento")
  neighborhood   String?       @map("bairro")
  city           String?       @map("cidade")
  state          String?       @map("uf")
  notes          String?       @map("observacoes")
  active         Boolean       @default(true) @map("ativo")
  shift          String?       @map("turno")
  appointments   Appointment[]

  @@map("Medico")
}

model Appointment {
  id               Int             @id @default(autoincrement())
  date             String          @map("data")
  slotTime         String          @map("horario")
  status           String?         @default("Agendado")
  patientId        Int             @map("pacienteId")
  doctorId         Int             @map("medicoId")
  accumulatedTime  Int?
  endTime          String?
  patientName      String?         @map("pacienteNome")
  pausedAt         String?
  professionalName String?         @map("profissionalNome")
  startTime        String?
  phone            String?         @map("telefone")
  whatsappSent     Boolean         @default(false)
  createdAt        DateTime        @default(now())
  doctor           Doctor          @relation(fields: [doctorId], references: [id])
  patient          Patient         @relation(fields: [patientId], references: [id])
  clinicalChart    ClinicalChart?  @relation("AppointmentClinicalChart")
  transaction      Transaction?

  @@map("Agendamento")
}

model ClinicalChart {
  id                   Int          @id @default(autoincrement())
  patientId            Int?         @map("pacienteId")
  birthDate            String?
  caregiver            String?
  clinicalDiagnosis    String?
  createdAt            DateTime     @default(now())
  diagnosisReactions   String?
  education            String?
  emotionalState       String?
  familyGuidance       String?
  gender               String?
  maritalStatus        String?
  occupation           String?
  patientLabel         String?      @map("patient")
  personalHistory      String?
  psychicExam          String?
  psychologicalConduct String?
  psychologist         String?
  religion             String?
  appointmentId        Int          @unique @map("agendamentoId")
  appointment          Appointment  @relation("AppointmentClinicalChart", fields: [appointmentId], references: [id])
  patient              Patient?     @relation(fields: [patientId], references: [id])

  @@map("prontuarios")
}

model Transaction {
  id             Int          @id @default(autoincrement())
  type           String       @map("tipo")
  category       String       @map("categoria")
  description    String       @map("descricao")
  amount         Float        @map("valor")
  date           String       @map("data")
  paymentMethod  String?      @map("formaPagamento")
  status         String       @default("Confirmado")
  appointmentId  Int?         @unique @map("agendamentoId")
  createdAt      DateTime     @default(now())
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("transacoes")
}

model FinancialConfig {
  id                   Int   @id @default(autoincrement())
  consultationFee      Float @map("valorConsulta")
  followUpFee          Float @map("valorRetorno")
  doctorCommissionRate Float @map("comissaoMedico")

  @@map("configuracao_financeira")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String?   @default("user")
  password      String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
