generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Paciente {
  id             Int           @id @default(autoincrement())
  nome           String
  dataNascimento String?
  sexo           String?
  cpf            String?       @unique
  telefone       String?
  email          String?
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  uf             String?
  convenio       String?
  numeroConvenio String?
  observacoes    String?
  estadoCivil    String?
  escolaridade   String?
  religiao       String?
  profissao      String?
  createdAt      DateTime      @default(now())
  agendamentos   Agendamento[]
  prontuarios    Prontuario[]

  @@map("pacientes")
}

model Medico {
  id             Int           @id @default(autoincrement())
  nome           String
  crm            String?
  especialidade  String?
  sexo           String?
  cpf            String?
  dataNascimento String?
  telefone       String?
  email          String?
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  uf             String?
  observacoes    String?
  ativo          Boolean       @default(true)
  turno          String?
  agendamentos   Agendamento[]
}

model Agendamento {
  id               Int         @id @default(autoincrement())
  data             String
  horario          String
  status           String?     @default("Agendado")
  pacienteId       Int
  medicoId         Int
  accumulatedTime  Int?
  endTime          String?
  pacienteNome     String?
  pausedAt         String?
  profissionalNome String?
  startTime        String?
  telefone         String?
  whatsappSent     Boolean     @default(false)
  createdAt        DateTime    @default(now())
  medico           Medico      @relation(fields: [medicoId], references: [id])
  paciente         Paciente    @relation(fields: [pacienteId], references: [id])
  prontuario       Prontuario? @relation("AgendamentoProntuario")
  transacao        Transacao?
  confirmacaoEmail ConfirmacaoAgendamentoEmail?
}

model ConfirmacaoAgendamentoEmail {
  id           Int         @id @default(autoincrement())
  agendamentoId Int        @unique
  tokenHash    String      @unique
  expiresAt    DateTime
  usedAt       DateTime?
  sentToEmail  String?
  createdAt    DateTime    @default(now())

  agendamento  Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)

  @@map("confirmacoes_agendamento_email")
}

model Prontuario {
  id                   Int         @id @default(autoincrement())
  pacienteId           Int?
  birthDate            String?
  caregiver            String?
  clinicalDiagnosis    String?
  createdAt            DateTime    @default(now())
  diagnosisReactions   String?
  education            String?
  emotionalState       String?
  familyGuidance       String?
  gender               String?
  maritalStatus        String?
  occupation           String?
  patient              String?
  personalHistory      String?
  psychicExam          String?
  psychologicalConduct String?
  psychologist         String?
  religion             String?
  agendamentoId        Int         @unique
  agendamento          Agendamento @relation("AgendamentoProntuario", fields: [agendamentoId], references: [id])
  paciente             Paciente?   @relation(fields: [pacienteId], references: [id])

  @@map("prontuarios")
}

model Transacao {
  id             Int          @id @default(autoincrement())
  tipo           String
  categoria      String
  descricao      String
  valor          Float
  data           String
  formaPagamento String?
  status         String       @default("Confirmado")
  agendamentoId  Int?         @unique
  createdAt      DateTime     @default(now())
  agendamento    Agendamento? @relation(fields: [agendamentoId], references: [id])

  @@map("transacoes")
}

model ConfiguracaoFinanceira {
  id             Int   @id @default(autoincrement())
  valorConsulta  Float
  valorRetorno   Float
  comissaoMedico Float

  @@map("configuracao_financeira")
}

// NextAuth.js Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String?   @default("user")
  password      String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
