generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Paciente {
  id             Int      @id @default(autoincrement())
  nome           String
  dataNascimento String?
  sexo           String?
  cpf            String?  @unique
  telefone       String?
  email          String?
  endereco       String?
  convenio       String?
  numeroConvenio String?
  observacoes    String?
  estadoCivil    String?
  escolaridade   String?
  religiao       String?
  profissao      String?
  createdAt      DateTime @default(now())

  // 🔗 RELAÇÕES
  agendamentos Agendamento[]
  prontuarios  Prontuario[]

  @@map("pacientes")
}

model Medico {
  id             Int      @id @default(autoincrement())
  nome           String
  crm            String?
  especialidade  String?
  sexo           String?
  cpf            String?
  dataNascimento String?
  telefone       String?
  email          String?
  endereco       String?
  observacoes    String?
  ativo          Boolean  @default(true)
  turno          String?

  agendamentos Agendamento[]
}

model Agendamento {
  id      Int    @id @default(autoincrement())
  data    String
  horario String
  status  String? @default("Agendado")

  // 🔥 SNAPSHOT (evita perder histórico se alterar paciente/médico)
  pacienteNome     String?
  profissionalNome String?
  telefone         String?

  // 🔥 CONTROLE DE ATENDIMENTO
  whatsappSent    Boolean @default(false)
  startTime       String?
  endTime         String?
  accumulatedTime Int?
  pausedAt        String?
  createdAt       DateTime @default(now())

  // 🔗 RELAÇÕES
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
  pacienteId Int

  medico   Medico @relation(fields: [medicoId], references: [id])
  medicoId Int

  prontuario Prontuario? @relation("AgendamentoProntuario")
  transacao  Transacao?
}

model Prontuario {
  id Int @id @default(autoincrement())

  // 🔥 RELAÇÃO 1:1 COM AGENDAMENTO
  agendamentoId Int         @unique
  agendamento   Agendamento @relation("AgendamentoProntuario", fields: [agendamentoId], references: [id])

  // 🔥 RELAÇÃO COM PACIENTE
  pacienteId Int?
  paciente   Paciente? @relation(fields: [pacienteId], references: [id])

  // 📄 DADOS
  patient   String?
  createdAt DateTime @default(now())

  gender               String?
  maritalStatus        String?
  birthDate            String?
  education            String?
  religion             String?
  occupation           String?
  caregiver            String?
  psychologist         String?
  clinicalDiagnosis    String?
  diagnosisReactions   String?
  emotionalState       String?
  personalHistory      String?
  psychicExam          String?
  psychologicalConduct String?
  familyGuidance       String?

  @@map("prontuarios")
}

model Transacao {
  id             Int      @id @default(autoincrement())
  tipo           String
  categoria      String
  descricao      String
  valor          Float
  data           String
  formaPagamento String?
  status         String   @default("Confirmado")
  createdAt      DateTime @default(now())

  // 🔥 RELAÇÃO 1:1
  agendamentoId Int         @unique
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id])

  @@map("transacoes")
}

model ConfiguracaoFinanceira {
  id             Int @id @default(autoincrement())
  valorConsulta  Float
  valorRetorno   Float
  comissaoMedico Float

  @@map("configuracao_financeira")
}

// NextAuth.js Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String?   @default("user")
  password      String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}