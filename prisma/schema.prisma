generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// Member names == persisted DB values, so the Prisma TS value,
// the DB label and the wire value are identical (no translation
// layer required). Values without a valid identifier (e.g. spaces)
// are normalized (ex.: "Em Atendimento" -> "EmAtendimento").
// ============================================================

enum Sex {
  Masculino
  Feminino
  Outro
}

enum AppointmentType {
  Consulta
  Retorno
}

enum AppointmentStatus {
  Agendado
  AguardandoConfirmacao
  Confirmado
  RegistrarChegada
  AguardandoPagamento
  Pago
  EmAtendimento
  Concluido
  Cancelado
  Reagendado
}

enum MedicalRecordStatus {
  DRAFT
  SIGNED
  AMENDED
}

enum TransactionType {
  Receita
  Despesa
}

enum TransactionStatus {
  Confirmado
  Pendente
  Cancelado
  Vencido
}

// ============================================================
// MASTER DATA
// ============================================================

model Patient {
  id              Int       @id @default(autoincrement())
  name            String
  cpf             String?   @unique @db.VarChar(11)
  birthDate       DateTime? @db.Date
  sex             Sex?
  phone           String?   @db.VarChar(20)
  email           String?
  zipCode         String?   @db.VarChar(9)
  street          String?
  number          String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?   @db.VarChar(2)
  insurancePlan   String?
  insuranceNumber String?
  maritalStatus   String?
  education       String?
  religion        String?
  profession      String?
  notes           String?
  image           String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  appointments   Appointment[]
  medicalRecords MedicalRecord[]

  @@index([name])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("patients")
}

model Specialty {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  active  Boolean  @default(true)
  doctors Doctor[]

  @@map("specialties")
}

model Doctor {
  id           Int       @id @default(autoincrement())
  name         String
  users        User[]
  crm          String?
  cpf          String?   @db.VarChar(11)
  birthDate    DateTime? @db.Date
  sex          Sex?
  phone        String?   @db.VarChar(20)
  email        String?
  zipCode      String?   @db.VarChar(9)
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?   @db.VarChar(2)
  notes        String?
  // Vocabulário controlado na camada de aplicação (rótulos PT acentuados).
  shift        String?
  active       Boolean   @default(true)

  specialtyId Int?
  specialty   Specialty? @relation(fields: [specialtyId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  appointments Appointment[]

  @@index([active])
  @@index([specialtyId])
  @@map("doctors")
}

// ============================================================
// SCHEDULING / CLINICAL ENCOUNTER
// ============================================================

model Appointment {
  id   Int             @id @default(autoincrement())
  type AppointmentType @default(Consulta)

  // Fonte de verdade temporal (a UI deriva data/horário no fuso local).
  scheduledStart DateTime  @db.Timestamptz(6)
  scheduledEnd   DateTime? @db.Timestamptz(6)

  status AppointmentStatus @default(Agendado)

  // Execução do atendimento (timer).
  startedAt     DateTime? @db.Timestamptz(6)
  endedAt       DateTime? @db.Timestamptz(6)
  pausedAt      DateTime? @db.Timestamptz(6)
  accumulatedMs Int       @default(0)
  whatsappSent  Boolean   @default(false)

  // Snapshots históricos (foto exibida no momento do agendamento).
  patientNameSnapshot      String?
  professionalNameSnapshot String?
  phoneSnapshot            String? @db.VarChar(20)

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId  Int
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Restrict)

  medicalRecord MedicalRecord?
  transaction   Transaction?
  procedures    AppointmentProcedure[]
  statusHistory AppointmentStatusHistory[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([doctorId, scheduledStart])
  @@index([scheduledStart])
  @@index([status])
  @@index([doctorId, scheduledStart])
  @@index([patientId, scheduledStart])
  @@map("appointments")
}

model AppointmentStatusHistory {
  id            Int                @id @default(autoincrement())
  appointmentId Int
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  fromStatus    AppointmentStatus?
  toStatus      AppointmentStatus
  changedById   String?
  changedBy     User?              @relation(fields: [changedById], references: [id], onDelete: SetNull)
  changedAt     DateTime           @default(now())

  @@index([appointmentId])
  @@index([toStatus, changedAt])
  @@map("appointment_status_history")
}

// ============================================================
// PRONTUÁRIO — sempre nasce de uma consulta (1:1 forte)
// ============================================================

model MedicalRecord {
  id Int @id @default(autoincrement())

  // Regra inegociável: prontuário SEMPRE pertence a uma consulta.
  appointmentId Int         @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Restrict)

  // Paciente obrigatório (derivado/validado a partir da consulta).
  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  status MedicalRecordStatus @default(DRAFT)

  // Conteúdo clínico.
  clinicalDiagnosis    String?
  diagnosisReactions   String?
  emotionalState       String?
  personalHistory      String?
  psychicExam          String?
  psychologicalConduct String?
  familyGuidance       String?
  caregiver            String?
  psychologist         String?

  // Snapshot demográfico (texto capturado no atendimento).
  patientLabel String? @map("patient")
  gender       String?
  birthDate    String?
  maritalStatus String?
  education     String?
  occupation   String?
  religion     String?

  // Auditoria clínica.
  createdById String?
  createdBy   User?     @relation("RecordAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  signedById  String?
  signedBy    User?     @relation("RecordSigner", fields: [signedById], references: [id], onDelete: SetNull)
  signedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  prescriptions Prescription[]
  attachments   Attachment[]

  @@index([patientId])
  @@index([status])
  @@index([createdAt])
  @@map("medical_records")
}

model Prescription {
  id              Int                @id @default(autoincrement())
  medicalRecordId Int
  medicalRecord   MedicalRecord      @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  notes           String?
  createdAt       DateTime           @default(now())
  items           PrescriptionItem[]

  @@index([medicalRecordId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             Int          @id @default(autoincrement())
  prescriptionId Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  drug           String
  dosage         String?
  instructions   String?

  @@index([prescriptionId])
  @@map("prescription_items")
}

model Attachment {
  id              Int           @id @default(autoincrement())
  medicalRecordId Int
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  fileName        String
  fileUrl         String
  mimeType        String?
  sizeBytes       Int?
  createdAt       DateTime      @default(now())

  @@index([medicalRecordId])
  @@map("attachments")
}

// ============================================================
// CATÁLOGO DE PROCEDIMENTOS / SERVIÇOS
// ============================================================

model Procedure {
  id           Int                    @id @default(autoincrement())
  name         String                 @unique
  defaultPrice Decimal                @db.Decimal(12, 2)
  active       Boolean                @default(true)
  createdAt    DateTime               @default(now())
  appointments AppointmentProcedure[]

  @@map("procedures")
}

model AppointmentProcedure {
  id            Int         @id @default(autoincrement())
  appointmentId Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  procedureId   Int
  procedure     Procedure   @relation(fields: [procedureId], references: [id], onDelete: Restrict)
  quantity      Int         @default(1)
  // Preço-snapshot: imutável mesmo que o catálogo mude depois.
  unitPrice     Decimal     @db.Decimal(12, 2)

  @@index([appointmentId])
  @@index([procedureId])
  @@map("appointment_procedures")
}

// ============================================================
// FINANCEIRO
// ============================================================

model Transaction {
  id            Int               @id @default(autoincrement())
  type          TransactionType
  category      String
  description   String
  amount        Decimal           @db.Decimal(12, 2)
  status        TransactionStatus @default(Confirmado)
  // Vocabulário controlado na aplicação (rótulos PT acentuados).
  paymentMethod String?

  competenceDate DateTime  @db.Date
  dueDate        DateTime? @db.Date
  paidAt         DateTime? @db.Timestamptz(6)

  appointmentId Int?         @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([type, status])
  @@index([competenceDate])
  @@index([status, competenceDate])
  @@map("transactions")
}

model FinancialConfig {
  id                   Int      @id @default(autoincrement())
  consultationFee      Decimal  @db.Decimal(12, 2)
  followUpFee          Decimal  @db.Decimal(12, 2)
  // Percentual 0–100 com 2 casas (ex.: 45.00).
  doctorCommissionRate Decimal  @db.Decimal(5, 2)
  updatedAt            DateTime @updatedAt

  @@map("financial_config")
}

// ============================================================
// MÉTRICAS (agregação opcional p/ dashboards de alto volume)
// ============================================================

model DailyMetricSnapshot {
  id                Int      @id @default(autoincrement())
  metricDate        DateTime @unique @db.Date
  appointmentsTotal Int      @default(0)
  appointmentsDone  Int      @default(0)
  noShowCount       Int      @default(0)
  cancelledCount    Int      @default(0)
  newPatients       Int      @default(0)
  recordsCreated    Int      @default(0)
  revenue           Decimal  @default(0) @db.Decimal(12, 2)
  expenses          Decimal  @default(0) @db.Decimal(12, 2)
  createdAt         DateTime @default(now())

  @@index([metricDate])
  @@map("daily_metric_snapshots")
}

// ============================================================
// AUTH (NextAuth) — role mantido como String (vocabulário em src/types/auth.ts)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String?   @default("MEDICO")
  password      String?
  active        Boolean   @default(true)
  doctorId      Int?
  doctor        Doctor?   @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  recordsAuthored MedicalRecord[]            @relation("RecordAuthor")
  recordsSigned   MedicalRecord[]            @relation("RecordSigner")
  transactions    Transaction[]
  statusChanges   AppointmentStatusHistory[]

  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]                   @relation("MessageSender")
  messageReads             MessageRead[]
  messageReactions         MessageReaction[]
  typingStatuses           TypingStatus[]
  notificationsCreated     Notification[]            @relation("NotificationCreator")
  notificationRecipients   NotificationRecipient[]
  userTasks                UserTask[]

  @@index([active])
  @@index([doctorId])
  @@map("users")
}

// ============================================================
// CHAT — mensagens em tempo real
// ============================================================

enum ConversationType {
  Direct
  Group
}

enum ChatMessageStatus {
  Sent
  Delivered
  Read
}

enum ChatAttachmentType {
  Image
  Video
  Pdf
  Document
  Link
}

model Conversation {
  id            Int              @id @default(autoincrement())
  title         String?
  type          ConversationType @default(Direct)
  lastMessageAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
  typingStatus TypingStatus[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             Int       @id @default(autoincrement())
  conversationId Int
  userId         String
  category       String?
  isFavorite     Boolean   @default(false)
  isMuted        Boolean   @default(false)
  isArchived     Boolean   @default(false)
  lastReadAt     DateTime?
  unreadCount    Int       @default(0)
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, isArchived])
  @@index([userId, category])
  @@map("conversation_participants")
}

model Message {
  id             Int               @id @default(autoincrement())
  conversationId Int
  senderId       String
  content        String?
  replyToId      Int?
  isEdited       Boolean           @default(false)
  isDeleted      Boolean           @default(false)
  status         ChatMessageStatus @default(Sent)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?            @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]           @relation("MessageReplies")
  reads        MessageRead[]
  attachments  ChatAttachment[]
  reactions    MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([conversationId, id])
  @@index([senderId])
  @@map("messages")
}

model MessageRead {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_reads")
}

model ChatAttachment {
  id           Int                @id @default(autoincrement())
  messageId    Int
  fileName     String
  fileUrl      String
  mimeType     String?
  sizeBytes    Int?
  type         ChatAttachmentType
  thumbnailUrl String?
  createdAt    DateTime           @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([type])
  @@map("chat_attachments")
}

model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model TypingStatus {
  id             Int      @id @default(autoincrement())
  conversationId Int
  userId         String
  isTyping       Boolean  @default(true)
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@map("typing_statuses")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum NotificationType {
  REMINDER
  STATUS_CHANGED
  APPOINTMENT
  FINANCE
  PATIENT
  SYSTEM
  MESSAGE
}

enum NotificationEntityType {
  Appointment
  Patient
  Transaction
  Task
  System
}

model Notification {
  id          String                  @id @default(cuid())
  type        NotificationType
  title       String?
  description String?
  entityId    String?
  entityType  NotificationEntityType?
  metadata    Json?
  createdAt   DateTime                @default(now())
  archivedAt  DateTime?
  deletedAt   DateTime?

  createdById String
  createdBy   User @relation("NotificationCreator", fields: [createdById], references: [id], onDelete: Cascade)

  recipients NotificationRecipient[]

  @@index([createdAt])
  @@index([type])
  @@index([createdById])
  @@index([deletedAt])
  @@map("notifications")
}

model NotificationRecipient {
  id             String    @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@index([userId, archivedAt])
  @@index([userId, createdAt])
  @@map("notification_recipients")
}

// ============================================================
// TASKS — tarefas manuais do dashboard (lembretes)
// ============================================================

enum UserTaskStatus {
  pending
  in_progress
  completed
}

enum UserTaskPriority {
  low
  medium
  high
}

model UserTask {
  id          Int              @id @default(autoincrement())
  title       String
  description String?
  dueAt       DateTime         @db.Timestamptz(6)
  status      UserTaskStatus   @default(pending)
  priority    UserTaskPriority @default(medium)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  @@index([userId, dueAt])
  @@index([status, dueAt])
  @@map("user_tasks")
}
